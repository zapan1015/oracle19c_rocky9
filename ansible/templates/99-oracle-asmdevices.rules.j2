# udev rules for Oracle ASM disks
# Generated by Ansible
# Requirements: 9.7, 9.8, 9.9, 9.10, 9.11

{% for disk in asm_disks %}
# {{ disk.name }} - {{ disk.diskgroup }} disk group ({{ disk.size }})
KERNEL=="{{ disk.device | basename }}", OWNER="{{ disk.owner }}", GROUP="{{ disk.group }}", MODE="{{ disk.mode }}"

{% endfor %}
